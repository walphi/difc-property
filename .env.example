# DIFC.property - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# Supabase Configuration
# =============================================================================
# Get these values from your Supabase project dashboard
# Project URL: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database connection string (for Prisma)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# =============================================================================
# Site Configuration
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://difc.property
NEXT_PUBLIC_SITE_NAME="DIFC.property"

# =============================================================================
# Contact Information
# =============================================================================
NEXT_PUBLIC_CONTACT_PHONE="+971562195566"
NEXT_PUBLIC_CONTACT_EMAIL="contact@difc.property"
NEXT_PUBLIC_OFFICE_ADDRESS="Office A-05, Al Saqr Business Tower, DIFC, Dubai, UAE"

# =============================================================================
# SEO & Analytics (Optional)
# =============================================================================
# Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console verification code
# NEXT_PUBLIC_GSC_VERIFICATION=your-verification-code

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
# Enable/disable features
NEXT_PUBLIC_ENABLE_NEWSLETTER=true
NEXT_PUBLIC_ENABLE_ENQUIRY_FORM=true
NEXT_PUBLIC_ENABLE_CHAT=false

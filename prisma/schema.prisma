// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Building {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  developer   String?
  address     String
  city        String   @default("Dubai")
  district    String   @default("DIFC")
  country     String   @default("UAE")
  latitude    Float?
  longitude   Float?
  completionYear Int?
  totalUnits  Int?
  buildingType String // residential, commercial, mixed-use
  amenities   String[] // Array of amenity names
  images      String[] // Array of image URLs
  featured    Boolean  @default(false)
  
  // Relations
  listings    Listing[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([slug])
  @@index([featured])
}

model Listing {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String?  @db.Text
  price         Int
  currency      String   @default("AED")
  pricePerSqft  Float?
  
  // Property details
  bedrooms      Int?
  bathrooms     Int?
  sqft          Int
  propertyType  String   // apartment, penthouse, duplex, etc.
  floor         String?
  unit          String?
  
  // Status
  status        String   @default("available") // available, under_offer, sold, rented
  featured      Boolean  @default(false)
  isNew         Boolean  @default(false)
  
  // Features
  amenities     String[]
  images        String[]
  floorPlans    String[]
  
  // Views & Features from title
  view          String?  // Burj Khalifa View, Zabeel View, DIFC View, etc.
  features      String[] // Upgraded, Vacant, Tenanted, etc.
  
  // Relations
  buildingId    String
  building      Building @relation(fields: [buildingId], references: [id])
  
  // Source information
  sourceName    String   @default("Edifice Brokerage")
  sourceUrl     String?
  sourceAgent   String?
  agentPhone    String?
  
  // SEO
  metaTitle     String?
  metaDescription String?
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  listedAt      DateTime @default(now())
  
  @@index([slug])
  @@index([buildingId])
  @@index([status])
  @@index([featured])
  @@index([price])
  @@index([bedrooms])
  @@index([propertyType])
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  type        String   // news, listing, area
  color       String?  // For UI theming
  
  // Relations
  articles    NewsArticle[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([slug])
  @@index([type])
}

model NewsArticle {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  content       String   @db.Text
  summary       String?  @db.Text
  excerpt       String?  // Short description for cards
  
  // Categorization
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  tags          String[]
  
  // Source information
  source        String?  // e.g., "DIFC Authority", "Gulf Business"
  sourceUrl     String?  // Original article URL
  author        String?
  
  // Media
  featuredImage String?
  images        String[]
  
  // SEO
  metaTitle     String?
  metaDescription String?
  
  // Status
  published     Boolean  @default(false)
  publishedAt   DateTime @default(now())
  featured      Boolean  @default(false)
  
  // Relations
  relatedListings String[] // Array of listing slugs
  relatedBuildings String[] // Array of building slugs
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([slug])
  @@index([categoryId])
  @@index([published])
  @@index([featured])
  @@index([publishedAt])
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String?  @db.Text
  
  // Lead source
  source      String   // listing, general, news, etc.
  listingId   String?  // If related to a specific listing
  
  // Status
  status      String   @default("new") // new, contacted, qualified, converted
  
  // Marketing
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
}

model SEOMetadata {
  id              String   @id @default(cuid())
  pagePath        String   @unique // e.g., "/listings", "/about"
  pageType        String   // home, listings, listing_detail, news, etc.
  
  // Meta tags
  title           String
  description     String
  keywords        String[]
  canonicalUrl    String?
  
  // Open Graph
  ogTitle         String?
  ogDescription     String?
  ogImage         String?
  ogType          String?  @default("website")
  
  // Twitter
  twitterCard     String?  @default("summary_large_image")
  twitterTitle    String?
  twitterDescription String?
  twitterImage    String?
  
  // Schema.org
  schemaType      String?  // RealEstateListing, BlogPosting, etc.
  schemaData      Json?    // Additional schema data
  
  // FAQs for structured data
  faqs            Json?    // Array of {question, answer}
  
  updatedAt       DateTime @updatedAt
  
  @@index([pagePath])
  @@index([pageType])
}
